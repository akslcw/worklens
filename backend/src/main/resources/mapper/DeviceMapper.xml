<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.worklens.backend.mapper.DeviceMapper">

    <resultMap id="BaseResultMap" type="Device">
        <id column="id" property="id"/>
        <result column="employee_id" property="employeeId"/>
        <result column="device_name" property="deviceName"/>
        <result column="mac_address" property="macAddress"/>
        <result column="last_online" property="lastOnline"/>
        <result column="current_app" property="currentApp"/>
        <result column="current_window" property="currentWindow"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findByMacAddress" resultMap="BaseResultMap">
        SELECT * FROM devices WHERE mac_address = #{macAddress}
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM devices WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO devices (employee_id, device_name, mac_address, last_online)
        VALUES (#{employeeId}, #{deviceName}, #{macAddress}, NOW())
    </insert>

    <update id="updateLastOnline">
        UPDATE devices SET last_online = NOW() WHERE id = #{id}
    </update>

    <select id="selectByMac" resultType="com.worklens.backend.entity.Device">
        SELECT * FROM devices WHERE mac_address = #{macAddress}
    </select>

    <update id="updateHeartbeat">
        UPDATE devices
        SET last_online = NOW(),
            current_app = #{currentApp},
            current_window = #{currentWindow}
        WHERE mac_address = #{macAddress}
    </update>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM devices ORDER BY last_online DESC
    </select>
</mapper>